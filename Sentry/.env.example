# Environment Configuration for Fake Profile Detection AI
# Copy this file to .env and modify as needed

# ML Model
MODEL_PATH=models/fake_profile_model.pkl
METRICS_PATH=models/model_metrics.json

# Data
DATA_DIR=data

# API
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Database (SQLite — file-based, no extra server needed)
# For production with Docker, the path is overridden in docker-compose.yml
DATABASE_URL=sqlite:///predictions.db

# Logging
LOG_LEVEL=INFO

# Instagram (optional — for better fetch reliability if anonymous access is restricted)
# INSTAGRAM_USER=your_instagram_username
# INSTAGRAM_PASSWORD=your_instagram_password

# ML Training
TEST_SIZE=0.20
RANDOM_STATE=42

# --- Production / Deployment ---
# PORT is used by Render, Railway, Heroku (they inject it automatically)
# PORT=8000
